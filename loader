local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")

repeat task.wait() until Players.LocalPlayer

local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 5
        })
    end)
end

local Scripts = {
    [76558904092080] = "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/TheForge",
    [130247632398296] = "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/shootaboss.txt",
    [12495498157] = "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/fnaf_co_op.txt",
    [1537690962] = "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/BeeSwarm",
    [114640202062357] = "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/SwingObbyforBrainrots!"
    [123657429151726] = "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/Guess%20my%20number"
    [11534222714] =  "https://raw.githubusercontent.com/VortexScriptsS/Vortex-Scripts/refs/heads/main/AotFw"
}

local scriptUrl = Scripts[game.PlaceId]
if not scriptUrl then
    notify("Unsupported Game", "This game is not supported by Vortex Hub")
    return
end

notify("Vortex Hub", "Loading script...")

local success, response = pcall(function()
    return game:HttpGet(scriptUrl)
end)

if not success or type(response) ~= "string" or #response == 0 then
    notify("Load Failed", "Failed to fetch script.")
    return
end

local loaded, err = pcall(function()
    loadstring(response)()
end)

if not loaded then
    notify("Execution Error", "Script failed to run.")
end
