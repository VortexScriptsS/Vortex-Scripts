ShiftersTab:CreateSection("Eyes Hitbox")

-- Eyes Hitbox for Titan Models
local originalTitanEyesProperties = {}
local titanEyesVisualizationEnabled = false
local titanEyesConnection = nil

local currentShifterTitanEyesSizeX = 2
local currentShifterTitanEyesSizeY = 2
local currentShifterTitanEyesSizeZ = 2
local currentShifterTitanEyesTransparency = 0.5
local currentShifterTitanEyesColor = Color3.fromRGB(128, 255, 128)

-- Cache SEyes parts for performance
local cachedSEyesParts = {}

local function updateSEyesCache()
    cachedSEyesParts = {}
    for _, part in ipairs(workspace:GetDescendants()) do
        if part.Name == "SEyes" and part:IsA("BasePart") then
            local parent = part.Parent
            while parent and parent ~= workspace do
                if string.find(parent.Name, "Titan", 1, true) then
                    table.insert(cachedSEyesParts, part)
                    break
                end
                parent = parent.Parent
            end
        end
    end
end

local function applyToCachedSEyes(settings)
    for _, part in ipairs(cachedSEyesParts) do
        if part and part.Parent then
            HitboxManager:Apply(part, settings)
        end
    end
end

local function getTitanEyesFromTitanModels()
    local eyes = {}
    
    -- Search through workspace for models with "Titan" in their name
    for _, child in pairs(workspace:GetChildren()) do
        if child:IsA("Model") and string.find(child.Name, "Titan", 1, true) and not child:IsA("Folder") then
            -- Look for SEyes in this titan model
            local eyesPart = child:FindFirstChild("SEyes", true)
            if eyesPart then
                table.insert(eyes, eyesPart)
            end
        end
    end
    
    return eyes
end

local function saveOriginalTitanEyes(parts)
    for _, part in pairs(parts) do
        if not originalTitanEyesProperties[part] then
            local success, data = pcall(function()
                return {
                    Size = part.Size,
                    Transparency = part.Transparency,
                    Color = part.Color,
                    Material = part.Material
                }
            end)
            
            if success and data then
                originalTitanEyesProperties[part] = data
            end
        end
    end
end

local function applyToTitanEyes(parts)
    for _, part in pairs(parts) do
        if not originalTitanEyesProperties[part] then
            saveOriginalTitanEyes({part})
        end
        
        local original = originalTitanEyesProperties[part]
        if not original then return end
        
        pcall(function()
            local newSize = Vector3.new(
                original.Size.X * currentShifterTitanEyesSizeX,
                original.Size.Y * currentShifterTitanEyesSizeY,
                original.Size.Z * currentShifterTitanEyesSizeZ
            )
            part.Size = newSize
            part.Transparency = currentShifterTitanEyesTransparency
            part.Color = currentShifterTitanEyesColor
            part.Material = Enum.Material.Neon
        end)
    end
end

local function applyTitanEyesToAll()
    local eyes = getTitanEyesFromTitanModels()
    if #eyes > 0 then
        applyToTitanEyes(eyes)
    end
end

local function resetAllTitanEyes()
    for part, original in pairs(originalTitanEyesProperties) do
        if part and part.Parent then
            pcall(function()
                part.Size = original.Size
                part.Transparency = original.Transparency
                part.Color = original.Color
                part.Material = original.Material
            end)
        end
    end
    originalTitanEyesProperties = {}
end

local function startTitanEyesMonitoring()
    if titanEyesConnection then return end
    
    titanEyesConnection = workspace.DescendantAdded:Connect(function(part)
        if part.Name == "SEyes" and part:IsA("BasePart") then
            local parent = part.Parent
            while parent and parent ~= workspace do
                if string.find(parent.Name, "Titan", 1, true) then
                    task.wait(0.1)
                    if titanEyesVisualizationEnabled then
                        applyToTitanEyes({part})
                    end
                    break
                end
                parent = parent.Parent
            end
        end
    end)
end

local function stopTitanEyesMonitoring()
    if titanEyesConnection then
        titanEyesConnection:Disconnect()
        titanEyesConnection = nil
    end
end

ShiftersTab:CreateToggle({
    Name = "Titan Shifter Eyes Hitbox",
    CurrentValue = false,
    Flag = "ShifterTitanEyesHitbox",
    Callback = function(Value)
        if Value then
            -- Update cache and apply to existing SEyes parts
            updateSEyesCache()
            applyToCachedSEyes({
                sizeX = currentShifterTitanEyesSizeX,
                sizeY = currentShifterTitanEyesSizeY,
                sizeZ = currentShifterTitanEyesSizeZ,
                transparency = currentShifterTitanEyesTransparency,
                color = currentShifterTitanEyesColor
            })
            
            -- Watch for new SEyes parts
            titanEyesConnection = workspace.DescendantAdded:Connect(function(part)
                if part.Name == "SEyes" and part:IsA("BasePart") then
                    local parent = part.Parent
                    while parent and parent ~= workspace do
                        if string.find(parent.Name, "Titan", 1, true) then
                            task.wait(0.1)
                            HitboxManager:Apply(part, {
                                sizeX = currentShifterTitanEyesSizeX,
                                sizeY = currentShifterTitanEyesSizeY,
                                sizeZ = currentShifterTitanEyesSizeZ,
                                transparency = currentShifterTitanEyesTransparency,
                                color = currentShifterTitanEyesColor
                            })
                            -- Add to cache
                            table.insert(cachedSEyesParts, part)
                            break
                        end
                        parent = parent.Parent
                    end
                end
            end)
        else
            if titanEyesConnection then
                titanEyesConnection:Disconnect()
                titanEyesConnection = nil
            end
            -- Only reset SEyes parts, not all hitboxes
            for _, part in ipairs(cachedSEyesParts) do
                if part and part.Parent then
                    HitboxManager:Reset(part)
                end
            end
            cachedSEyesParts = {}
        end
    end,
})

