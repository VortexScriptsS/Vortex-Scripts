local _cloneref = (cloneref or function(o) return o end)
local _game = _cloneref(game)

-- Fixed anchor_ui: Removed setfenv which causes fatal crashes on modern executors
local function anchor_ui(f)
    return (newcclosure or function(x) return x end)(f)
end

local _rawget = (clonefunction or function(f) return f end)(rawget)
local _hookfunc = (clonefunction or function(f) return f end)(hookfunction)
local _hookmeta = (clonefunction or function(f) return f end)(hookmetamethod)
local _getgc = (clonefunction or function(f) return f end)(getgc)
local _checkcaller = (clonefunction or function(f) return f end)(checkcaller)

local _ptr_a, _ptr_b

local function refresh_cache()
    local success, gc = pcall(_getgc, true)
    if not success then return end
    
    for _, v in pairs(gc) do
        if typeof(v) == "table" then
            local s, d = pcall(_rawget, v, "Detected")
            local s2, k = pcall(_rawget, v, "Kill")
            
            if s and typeof(d) == "function" and not _ptr_a then
                _ptr_a = d
                _hookfunc(_ptr_a, anchor_ui(function(id, info, ...)
                    return true 
                end))
            end

            if s2 and typeof(k) == "function" and not _ptr_b then
                _ptr_b = k
                _hookfunc(_ptr_b, anchor_ui(function() 
                    -- Removed warn to prevent potential recursive logging crashes
                end))
            end
        end
    end
end

-- Use pcall for identity shifts as some executors restrict this
pcall(function() setthreadidentity(2) end)
refresh_cache()

local oNamecall; oNamecall = _hookmeta(_game, "__namecall", anchor_ui(function(self, ...)
    local method = getnamecallmethod()
    if not _checkcaller() then
        -- Standardized method checks to prevent bypass detection
        if (method == "Kick" or method == "kick" or method == "Teleport") then
            return nil
        end
        if (method == "GetHttpRequest" or method == "PostAsync") then
            return nil
        end
    end
    return oNamecall(self, ...)
end))

local oInfo; oInfo = _hookfunc(getrenv().debug.info, anchor_ui(function(lvlOrFunc, specs)
    if not _checkcaller() then
        if (lvlOrFunc == _ptr_a or lvlOrFunc == _ptr_b) then
            return "C", "builtin", 0 
        end
    end
    return oInfo(lvlOrFunc, specs)
end))

local oIndex; oIndex = _hookmeta(_game, "__index", anchor_ui(function(self, key)
    if not _checkcaller() then
        if self == _game and (key == "JobId" or key == "PlaceId") then
            return "00000000-0000-0000-0000-000000000000"
        end
        if (self == _ptr_a or self == _ptr_b) then
            if key == "Name" then return "FrameHandler" end
            if key == "Parent" then return nil end
        end
    end
    return oIndex(self, key)
end))

-- Added a basic check to tostring to prevent string-conversion loops
local oTostring; oTostring = _hookmeta(_game, "__tostring", anchor_ui(function(self)
    if not _checkcaller() and (self == _ptr_a or self == _ptr_b) then
        return "function: 0x" .. string.reverse("abcdef123456") -- Static hex to avoid tostring({}) loops
    end
    return oTostring(self)
end))

pcall(function() setthreadidentity(7) end)

task.spawn(function()
    while task.wait(30) do -- Increased delay to reduce CPU spikes
        pcall(refresh_cache)
    end
end)
