local HitboxManager = {}
local activeConnections = {}
local originalProperties = {}

function HitboxManager:SaveOriginal(part)
    if not originalProperties[part] then
        originalProperties[part] = {
            Size = part.Size,
            Transparency = part.Transparency,
            Color = part.Color,
            Material = part.Material
        }
    end
end

function HitboxManager:Apply(part, settings)
    self:SaveOriginal(part)
    local orig = originalProperties[part]
    
    part.Size = Vector3.new(
        orig.Size.X * (settings.sizeX or 2),
        orig.Size.Y * (settings.sizeY or 2),
        orig.Size.Z * (settings.sizeZ or 2)
    )
    part.Transparency = settings.transparency or 0.5
    part.Color = settings.color or Color3.fromRGB(255, 0, 0)
    part.Material = Enum.Material.Neon
end

function HitboxManager:Reset(part)
    if originalProperties[part] and part.Parent then
        local orig = originalProperties[part]
        part.Size = orig.Size
        part.Transparency = orig.Transparency
        part.Color = orig.Color
        part.Material = orig.Material
    end
end

function HitboxManager:ResetAll()
    for part, _ in pairs(originalProperties) do
        self:Reset(part)
    end
    originalProperties = {}
end

function HitboxManager:Watch(folderName, partNames, settings, isRecursive)
    local folder = workspace:WaitForChild(folderName)
    
    -- Apply to existing
    for _, titan in ipairs(folder:GetChildren()) do
        for _, partName in ipairs(partNames) do
            local part = isRecursive and titan:FindFirstChild(partName, true) or titan:FindFirstChild(partName)
            if part then
                self:Apply(part, settings)
            end
        end
    end
    
    -- Watch for new
    local conn = folder.ChildAdded:Connect(function(titan)
        task.wait(0.1)
        for _, partName in ipairs(partNames) do
            local part = isRecursive and titan:FindFirstChild(partName, true) or titan:FindFirstChild(partName)
            if part then
                self:Apply(part, settings)
            end
        end
    end)
    
    table.insert(activeConnections, conn)
    return conn
end

function HitboxManager:Stop()
    for _, conn in ipairs(activeConnections) do
        conn:Disconnect()
    end
    activeConnections = {}
    self:ResetAll()
end

