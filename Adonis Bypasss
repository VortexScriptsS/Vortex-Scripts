local _cloneref = (cloneref or function(o) return o end)
local _game = _cloneref(game)

local function anchor_ui(f)
    local wrapped = (newcclosure or function(x) return x end)(f)
    -- Wrap in pcall to prevent the 'cannot change environment' crash
    pcall(function()
        if setfenv then setfenv(wrapped, getfenv(0)) end
    end)
    return wrapped
end

local _rawget = clonefunction(rawget)
local _hookfunc = clonefunction(hookfunction)
local _hookmeta = clonefunction(hookmetamethod)
local _getgc = clonefunction(getgc)
local _checkcaller = clonefunction(checkcaller)

local _ptr_a, _ptr_b

local function refresh_cache()
    for _, v in _getgc(true) do
        if typeof(v) == "table" then
            local s, d = pcall(_rawget, v, "Detected")
            local s2, k = pcall(_rawget, v, "Kill")
            
            if s and typeof(d) == "function" and not _ptr_a then
                _ptr_a = d
                _hookfunc(_ptr_a, anchor_ui(function(id, info, ...)
                    if id == "Check" or id == "Test" then return true end
                    warn("UI Driver: Buffer overflow on " .. tostring(id)) 
                    return true 
                end))
            end

            if s2 and typeof(k) == "function" and not _ptr_b then
                _ptr_b = k
                _hookfunc(_ptr_b, anchor_ui(function() 
                    warn("UI Driver: Context lost, recovering...") 
                end))
            end
        end
    end
end

setthreadidentity(2)
refresh_cache()

local oNamecall; oNamecall = _hookmeta(_game, "__namecall", anchor_ui(function(self, ...)
    local method = getnamecallmethod()
    if not _checkcaller() then
        if (method == "Kick" or method == "kick" or method == "Teleport") then
            warn("UI Driver: Suppressed external request.")
            return nil
        end
        if (method == "GetHttpRequest" or method == "PostAsync") then
            warn("UI Driver: Data transmission paused.")
            return nil
        end
    end
    return oNamecall(self, ...)
end))

local oInfo; oInfo = _hookfunc(getrenv().debug.info, anchor_ui(function(...)
    if not _checkcaller() then
        local target = ...
        if (_ptr_a and target == _ptr_a) or (_ptr_b and target == _ptr_b) then
            return "C", "builtin", 0 
        end
    end
    return oInfo(...)
end))

local oIndex; oIndex = _hookmeta(_game, "__index", anchor_ui(function(self, key)
    if not _checkcaller() then
        if self == _game and (key == "JobId" or key == "PlaceId") then
            return "00000000-0000-0000-0000-000000000000"
        end
        if (self == _ptr_a or self == _ptr_b) then
            if key == "Name" then return "FrameHandler" end
            if key == "Parent" then return nil end
        end
    end
    return oIndex(self, key)
end))

local oTostring; oTostring = _hookmeta(_game, "__tostring", anchor_ui(function(self)
    if not _checkcaller() and (self == _ptr_a or self == _ptr_b) then
        return "function: 0x" .. string.lower(string.sub(tostring({}), 10)) 
    end
    return oTostring(self)
end))

setthreadidentity(7)

task.spawn(function()
    while task.wait(25) do
        pcall(refresh_cache)
    end
end)
