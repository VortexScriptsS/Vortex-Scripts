-- Combined Leg Tendons Hitbox
local originalLegTendonsProperties = {}
local legTendonsVisualizationEnabled = false
local legTendonsConnection = nil

local currentLegTendonsSizeX = 2
local currentLegTendonsSizeY = 2
local currentLegTendonsSizeZ = 2
local currentLegTendonsTransparency = 0.5
local currentLegTendonsColor = Color3.fromRGB(255, 0, 255)

local function getLegTendonsFromTitanModels()
    local legTendons = {}
    
    -- Search through workspace for models with "Titan" in their name
    for _, child in pairs(workspace:GetChildren()) do
        if child:IsA("Model") and string.find(child.Name, "Titan", 1, true) and not child:IsA("Folder") then
            -- Look for both RLegTendons and LLegTendons in this titan model
            local rLegTendonsPart = child:FindFirstChild("RLegTendons", true)
            if rLegTendonsPart then
                table.insert(legTendons, rLegTendonsPart)
            end
            
            local lLegTendonsPart = child:FindFirstChild("LLegTendons", true)
            if lLegTendonsPart then
                table.insert(legTendons, lLegTendonsPart)
            end
        end
    end
    
    return legTendons
end

local function saveOriginalLegTendons(parts)
    for _, part in pairs(parts) do
        if not originalLegTendonsProperties[part] then
            local success, data = pcall(function()
                return {
                    Size = part.Size,
                    Transparency = part.Transparency,
                    Color = part.Color,
                    Material = part.Material
                }
            end)
            
            if success and data then
                originalLegTendonsProperties[part] = data
            end
        end
    end
end

local function applyToLegTendons(parts)
    for _, part in pairs(parts) do
        if not originalLegTendonsProperties[part] then
            saveOriginalLegTendons({part})
        end
        
        local original = originalLegTendonsProperties[part]
        if not original then return end
        
        pcall(function()
            local newSize = Vector3.new(
                original.Size.X * currentLegTendonsSizeX,
                original.Size.Y * currentLegTendonsSizeY,
                original.Size.Z * currentLegTendonsSizeZ
            )
            part.Size = newSize
            part.Transparency = currentLegTendonsTransparency
            part.Color = currentLegTendonsColor
            part.Material = Enum.Material.Neon
        end)
    end
end

local function applyLegTendonsToAll()
    local legTendons = getLegTendonsFromTitanModels()
    if #legTendons > 0 then
        applyToLegTendons(legTendons)
    end
end

local function resetAllLegTendons()
    for part, original in pairs(originalLegTendonsProperties) do
        if part and part.Parent then
            pcall(function()
                part.Size = original.Size
                part.Transparency = original.Transparency
                part.Color = original.Color
                part.Material = original.Material
            end)
        end
    end
    originalLegTendonsProperties = {}
end

local function startLegTendonsMonitoring()
    if legTendonsConnection then return end
    
    legTendonsConnection = workspace.DescendantAdded:Connect(function(part)
        if (part.Name == "RLegTendons" or part.Name == "LLegTendons") and part:IsA("BasePart") then
            local parent = part.Parent
            while parent and parent ~= workspace do
                if string.find(parent.Name, "Titan", 1, true) then
                    task.wait(0.1)
                    if legTendonsVisualizationEnabled then
                        applyToLegTendons({part})
                    end
                    break
                end
                parent = parent.Parent
            end
        end
    end)
end

local function stopLegTendonsMonitoring()
    if legTendonsConnection then
        legTendonsConnection:Disconnect()
        legTendonsConnection = nil
    end
end

