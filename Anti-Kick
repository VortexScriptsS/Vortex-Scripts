local Players = game:GetService("Players")

local function enableAntiKick()
	if not hookmetamethod then
		return false
	end

	local player = Players.LocalPlayer
	if not player then
		warn("LocalPlayer is nil. Make sure this is running on the client.")
		return false
	end

	local oldhmmi
	local oldhmmnc
	local oldKickFunction

	if hookfunction then
		oldKickFunction = hookfunction(player.Kick, function() end)
	end

	oldhmmi = hookmetamethod(game, "__index", function(self, method)
		if self == player and type(method) == "string" and method:lower() == "kick" then
			error("Expected ':' not '.' calling member function Kick", 2)
		end
		return oldhmmi(self, method)
	end)

	oldhmmnc = hookmetamethod(game, "__namecall", function(self, ...)
		local method = getnamecallmethod()
		if self == player and type(method) == "string" and method:lower() == "kick" then
			return
		end
		return oldhmmnc(self, ...)
	end)

	return true
end

enableAntiKick()
