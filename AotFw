local function makeToggle()
    return {
        on = false,
        task = nil,
        respawn = nil
    }
end

local function startLoop(toggle, loopFunc, respawnFunc)
    if toggle.task then return end
    
    toggle.task = task.spawn(function()
        if respawnFunc then
            toggle.respawn = LocalPlayer.CharacterAdded:Connect(function()
                if toggle.on and respawnFunc then
                    respawnFunc()
                end
            end)
        end
        
        while toggle.on do
            loopFunc()
        end
        
        if toggle.respawn then
            toggle.respawn:Disconnect()
            toggle.respawn = nil
        end
        toggle.task = nil
    end)
end

local function stopLoop(toggle)
    toggle.on = false
    if toggle.task then
        toggle.task = nil
    end
    if toggle.respawn then
        toggle.respawn:Disconnect()
        toggle.respawn = nil
    end
end


