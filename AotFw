local titanDamageToggle = makeToggle()
local oldNamecall = nil
local currentDamage = 1170

local function isTitanPart(target)
    if not target or not target.Parent then return false end
    
    -- Check if target is any descendant of OnGameTitans (Nape, Eyes, Limbs, etc.)
    local parent = target.Parent
    while parent and parent ~= game do
        if parent.Name == "OnGameTitans" then
            return true
        end
        parent = parent.Parent
    end
    return false
end

local function setupHook()
    if oldNamecall then return end
    
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        
        -- Only intercept HitEvent FireServer calls
        if method == "FireServer" and self.Name == "HitEvent" and titanDamageToggle.on then
            local args = {...}
            
            -- Check if this is any Titan part hit with damage argument
            if #args >= 2 and isTitanPart(args[1]) and type(args[2]) == "number" then
                args[2] = currentDamage  -- Modify damage to current slider value
                return oldNamecall(self, unpack(args))
            end
        end
        
        return oldNamecall(self, ...)
    end)
end

local function removeHook()
    titanDamageToggle.on = false
end

TitanTab:CreateToggle({
    Name = "Enable Damage Modifier",
    CurrentValue = false,
    Flag = "TitanDamageModifier",
    Callback = function(Value)
        titanDamageToggle.on = Value
        
        if Value then
            setupHook()
        else
            removeHook()
        end
    end,
})

