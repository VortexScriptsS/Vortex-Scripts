local function setSkillState(state)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        local skillsGui = playerGui:FindFirstChild("SkillsGui")
        if skillsGui then
            for _, skill in ipairs(skills) do
                local gui = skillsGui:FindFirstChild(skill)
                if gui then
                    if gui:IsA("ScreenGui") then
                        gui.Enabled = state
                    elseif gui:IsA("GuiObject") then
                        gui.Visible = state
                    end
                end
            end
        end
    end

    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            local gear = humanoid:FindFirstChild("Gear")
            if gear then
                local skills = gear:FindFirstChild("Skills")
                if skills then
                    for _, skill in ipairs(skills:GetChildren()) do
                        if skill and skill:IsA("BoolValue") then
                            skill.Value = state
                        end
                    end
                end
            end
        end
    end
end

local function turnOnSkills()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    playerGui:WaitForChild("SkillsGui", 5)

    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        local gear = humanoid:WaitForChild("Gear", 5)
        if gear then
            gear:WaitForChild("Skills", 5)
        end
    end

    setSkillState(true)
end

local function turnOffSkills()
    setSkillState(false)
end

