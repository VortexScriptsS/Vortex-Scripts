local function checkStaff()
    local playersData = workspace:FindFirstChild("PlayersDataFolder")
    if not playersData then return end
    
    local currentPlayers = {}
    for _, folder in pairs(playersData:GetChildren()) do
        if folder:IsA("Folder") then
            currentPlayers[folder.Name] = true
        end
    end
    
    for name in pairs(staffList) do
        if not currentPlayers[name] then
            staffList[name] = nil
            
        end
    end
    
    for _, folder in pairs(playersData:GetChildren()) do
        if folder:IsA("Folder") then
            local staffTag = folder:FindFirstChild("StaffTag")
            if staffTag and staffTag:IsA("IntValue") then
                local level = staffTag.Value
                local name = folder.Name
                
                if level >= 1 then
                    if not staffList[name] or staffList[name] ~= level then
                        staffList[name] = level
                        
                        Rayfield:Notify({
                            Title = "Staff Detected",
